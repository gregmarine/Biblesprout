<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- E-ink: pure black on white, no action bar, NotoSerif everywhere. Motion/
         refresh rules live in docs/eink-constraints.md and are enforced in code. -->
    <style name="Theme.Biblesprout" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/eink_white</item>
        <item name="colorPrimary">@color/eink_black</item>
        <item name="colorAccent">@color/eink_black</item>
        <item name="android:textColorPrimary">@color/eink_black</item>
        <item name="android:fontFamily">@font/noto_serif</item>
        <!-- No activity open/close animation: motion ghosts on e-ink. -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
