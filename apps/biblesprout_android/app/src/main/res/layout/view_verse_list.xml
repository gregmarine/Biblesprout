<?xml version="1.0" encoding="utf-8"?>
<!-- A paginated list of verse rows with e-ink paging chrome (swipe or arrows).
     Shared by Find's search results and the word-study concordance; driven by
     VerseListPager. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.symmetricalpalmtree.biblesprout.ui.SwipePager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/eink_rule" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/prev"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/previous_page"
            android:src="@drawable/ic_chevron_left" />

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/eink_rule"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/next"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/next_page"
            android:src="@drawable/ic_chevron_right" />
    </LinearLayout>
</LinearLayout>
