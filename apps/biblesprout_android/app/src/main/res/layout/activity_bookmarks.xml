<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/eink_white"
    android:paddingTop="@dimen/top_safe_gap">

    <!-- Top bar: back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/bookmarks"
            android:textColor="@color/eink_black"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/eink_black" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.symmetricalpalmtree.biblesprout.ui.SwipePager
            android:id="@+id/pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:lineSpacingMultiplier="1.3"
            android:text="@string/no_bookmarks"
            android:textColor="@color/eink_rule"
            android:textSize="17sp"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/eink_rule" />

    <!-- Footer: paging arrows + page indicator -->
    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/prev"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/previous_page"
            android:src="@drawable/ic_chevron_left" />

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/eink_rule"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/next"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/next_page"
            android:src="@drawable/ic_chevron_right" />
    </LinearLayout>
</LinearLayout>
