<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/eink_white">

    <!-- Header: title + translation + search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/eink_black"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/translation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/loading"
                android:textColor="@color/eink_rule"
                android:textSize="15sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/search"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="13dp"
            android:contentDescription="@string/find"
            android:src="@drawable/ic_search" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/eink_black" />

    <!-- Paged table of contents -->
    <com.symmetricalpalmtree.biblesprout.ui.SwipePager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/eink_rule" />

    <!-- Footer: paging arrows + page indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/prev"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/previous_page"
            android:src="@drawable/ic_chevron_left" />

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/eink_rule"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/next"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="@string/next_page"
            android:src="@drawable/ic_chevron_right" />
    </LinearLayout>
</LinearLayout>
